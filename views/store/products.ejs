<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Products</title>
<link rel="stylesheet" href="/css/styles.css">
</head>

<body>

<h1>Products Page</h1>

<div class="row">

<% products.forEach(product => { %>

<div class="box">

<img src="<%= product.imageUrl %>" width="300">

<h2><%= product.name %></h2>

<p><%= product.desc %></p>

<h4>₹<%= product.price %></h4>

</div>

<% }) %>

</div>

</body>
</html>